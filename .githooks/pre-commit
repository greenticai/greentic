#!/usr/bin/env bash
#
# Pre-commit hook — runs the CI-critical gates locally (fmt, clippy, tests) so
# regressions like a formatting slip or a broken test are caught before they
# reach a PR and fail in CI. The gate arguments mirror `.github` pr-ci:
#   clippy:  --workspace --all-targets --all-features -- -D warnings
#   test:    --workspace --all-features
#
# Enable once per clone (also done by `ci/install-hooks.sh`):
#
#     git config core.hooksPath .githooks
#
# In a genuine emergency a single commit can bypass the hook with:
#
#     SKIP_PRECOMMIT=1 git commit …
#
set -euo pipefail

if [[ "${SKIP_PRECOMMIT:-0}" == "1" ]]; then
  echo "pre-commit: skipped via SKIP_PRECOMMIT=1" >&2
  exit 0
fi

# Run from the repo root so cargo finds the manifest no matter which
# subdirectory `git commit` was invoked from.
cd "$(git rev-parse --show-toplevel)"

echo "pre-commit [1/3] cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "pre-commit [2/3] cargo clippy --workspace --all-targets --all-features -- -D warnings"
cargo clippy --workspace --all-targets --all-features -- -D warnings

echo "pre-commit [3/3] cargo test --workspace --all-features"
cargo test --workspace --all-features

echo "pre-commit: all checks passed"
